# ============================================
# Echo — Social Media Agent Configuration
# ============================================
# Copy this file to echo.env and fill in your credentials.
# NEVER commit echo.env to version control.

# Reddit
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_USER_AGENT=halo-ai-echo/1.0

# X / Twitter
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# Hacker News
HN_USERNAME=your_hn_username
HN_PASSWORD=your_hn_password

# YouTube
YOUTUBE_API_KEY=your_youtube_api_key

# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token

# Echo Settings
ECHO_DATA_DIR=/srv/ai/echo/data
ECHO_KEYWORDS=halo-ai,strix halo,AMD AI,bare metal LLM,halo ai
ECHO_NOTIFY=true
